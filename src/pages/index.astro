          <rect width="700" height="480" fill="#f4efe6"/>
          <!-- River & Forest Hills Background -->
          <path d="M0 320 Q200 270 400 320 T700 290 L700 480 L0 480 Z" fill="#2d4a3e" opacity="0.18"/>
          <path d="M0 365 Q250 330 450 375 T700 345 L700 480 L0 480 Z" fill="#22382d" opacity="0.35"/>
          <path d="M-50 415 Q150 395 350 435 T750 405 L750 480 L-50 480 Z" fill="#1c3327"/>
          <!-- Ringarooma River Stroke -->
          <path d="M0 445 Q300 415 700 455" stroke="#7a9a8b" stroke-width="14" opacity="0.75"/>
          
          <!-- Twin Timber Cabins -->
          <polygon points="170,270 170,205 250,155 330,205 330,270" fill="#a85e2e"/>
          <rect x="230" y="220" width="30" height="50" fill="#faf8f5"/>
          <rect x="190" y="215" width="26" height="26" fill="#e6ded2"/>
          <rect x="274" y="215" width="26" height="26" fill="#e6ded2"/>

          <polygon points="410,240 410,175 490,125 570,175 570,240" fill="#8f4e24"/>
          <rect x="470" y="190" width="30" height="50" fill="#faf8f5"/>
          <rect x="430" y="185" width="26" height="26" fill="#e6ded2"/>
          <rect x="514" y="185" width="26" height="26" fill="#e6ded2"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Key Highlights Bar -->
  <section class="highlights-bar">
    <div class="container">
      <div class="highlights-flex">
        <div class="highlight-box">
          <span class="highlight-number">2</span>
          <span class="highlight-label">Standalone Timber Cabins</span>
        </div>
        <div class="highlight-divider"></div>
        <div class="highlight-box">
          <span class="highlight-number">10</span>
          <span class="highlight-label">Max Capacity (Booked Together)</span>
        </div>
        <div class="highlight-divider"></div>
        <div class="highlight-box">
          <span class="highlight-icon">🔒</span>
          <span class="highlight-label">Private Keypad Bike Sheds</span>
        </div>
        <div class="highlight-divider"></div>
        <div class="highlight-box">
          <span class="highlight-icon">🌲</span>
          <span class="highlight-label">Minutes to Blue Derby Trails</span>
