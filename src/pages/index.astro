---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Navigation Header -->
  <header class="header">
    <div class="container header-content">
      <a href="#" class="brand">
        <span class="brand-title">The Derby Double</span>
        <span class="brand-sub">1B Bell St, Derby TAS</span>
      </a>

      <nav class="nav-desktop">
        <a href="#about" class="nav-link">About</a>
        <a href="#cabins" class="nav-link">The Cabins</a>
        <a href="#gallery" class="nav-link">Photo Gallery</a>
        <a href="#amenities" class="nav-link">Amenities</a>
        <a href="#location" class="nav-link">Location</a>
      </nav>

      <a href="#cabins" class="btn btn-primary btn-sm" id="nav-book-btn">
        <span>Book Your Stay</span>
      </a>
    </div>
  </header>

  <!-- Hero Section -->
