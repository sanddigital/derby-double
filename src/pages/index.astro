    <div class="container hero-container">
      <div class="hero-text-block animate-fade-in">
        <div class="hero-badge-group">
          <span class="badge">1B Bell St, Derby TAS</span>
          <span class="badge badge-timber">Ringarooma River Views</span>
        </div>

        <h1 class="hero-heading">
          A secluded nature retreat above the Ringarooma River.
        </h1>

        <p class="hero-lead">
          Welcome to <strong>The Derby Double</strong> — twin architecturally designed timber cabins located at 1B Bell St, Derby, Tasmania. Purpose-built for Blue Derby mountain bike riders, families, and nature retreats.
        </p>

        <div class="hero-cta-row">
          <a href="#cabins" class="btn btn-primary" id="hero-cabins-btn">
            <span>View Cabins & Availability</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 5v14M5 12l7 7 7-7"/>
            </svg>
          </a>
          <a href="#gallery" class="btn btn-outline" id="hero-gallery-btn">
            <span>Explore Photo Gallery</span>
          </a>
        </div>
      </div>

      <!-- Natural Hero Image Illustration Container -->
      <div class="hero-visual-card">
